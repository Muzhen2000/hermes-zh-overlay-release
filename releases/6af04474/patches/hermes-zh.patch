+"""Regression tests for localized gateway slash-command replies."""
+
+from __future__ import annotations
+
+import os
+from pathlib import Path
+from unittest.mock import MagicMock, patch
+
+import pytest
+
+from gateway.config import Platform
+from gateway.platforms.base import MessageEvent
+from gateway.session import SessionSource
+
+
+def _write_ui_overlay():
+    localization_dir = Path(os.environ["HERMES_HOME"]) / "localization"
+    localization_dir.mkdir(parents=True, exist_ok=True)
+    (localization_dir / "ui.zh-CN.yaml").write_text(
+        """messages:
+  gateway.runtime.title.db_unavailable: 会话数据库不可用。
+  gateway.runtime.title.empty: ⚠️ 标题清理后为空，请使用可见字符。
+  gateway.runtime.title.set: ✏️ 会话标题已设置：**{title}**
+  gateway.runtime.title.not_found: 数据库中没有找到当前会话。
+  gateway.runtime.title.show: "📌 会话：`{session_id}`\\n标题：**{title}**"
+  gateway.runtime.title.none: "📌 会话：`{session_id}`\\n还没有设置标题。用法：`/title 我的会话名`"
+  gateway.runtime.resume.db_unavailable: 会话数据库不可用。
+  gateway.runtime.resume.none_found: 没有找到已命名会话。
+  gateway.runtime.resume.usage_hint: 使用 `/title 我的会话` 命名当前会话，再用 `/resume 我的会话` 回到它。
+  gateway.runtime.resume.not_found: "没有找到匹配 **{name}** 的会话。\\n不带参数使用 `/resume` 查看可用会话。"
+  gateway.runtime.resume.already_on: 📌 已经在会话 **{name}** 中。
+  gateway.runtime.resume.switch_failed: 切换会话失败。
+  gateway.runtime.resume.resumed: ↻ 已恢复会话 **{title}**{msg_part}。对话已恢复。
+  gateway.runtime.branch.db_unavailable: 会话数据库不可用。
+  gateway.runtime.branch.no_conversation: 还没有可分叉的对话，请先发送一条消息。
+  gateway.runtime.branch.create_failed: 创建分叉会话失败：{error}
+  gateway.runtime.branch.switch_failed: 分叉已创建，但切换失败。
+  gateway.runtime.approval.approve.no_pending: 没有等待批准的命令。
+  gateway.runtime.approval.deny.no_pending: 没有等待拒绝的命令。
+  gateway.runtime.approval.deny.stale: ❌ 命令已拒绝（批准已过期）。
+  gateway.runtime.update.only_messaging: ✗ /update 只能从消息平台使用。请在终端运行 `hermes update`。
+  gateway.runtime.update.not_git: ✗ 当前不是 git 仓库，无法更新。
+  gateway.runtime.update.no_binary: ✗ 找不到 `hermes` 命令。请在终端手动运行 `hermes update`。
+  gateway.runtime.update.start_failed: ✗ 启动更新失败：{error}
+  gateway.runtime.update.start: ⚕ 正在启动 Hermes 更新……我会在这里同步进度。
+  gateway.runtime.insights.invalid_days: --days 参数无效：{value}
+  gateway.runtime.insights.error: 生成 insights 失败：{error}
+  gateway.runtime.reload.failed: ❌ MCP 重载失败：{error}
+""",
+        encoding="utf-8",
+    )
+
+
+def _make_event(text: str = "/title", platform: Platform = Platform.TELEGRAM) -> MessageEvent:
+    return MessageEvent(
+        text=text,
+        source=SessionSource(platform=platform, user_id="u1", chat_id="c1", user_name="tester"),
+    )
+
+
+def _make_runner():
+    from gateway.run import GatewayRunner
+
+    runner = object.__new__(GatewayRunner)
+    runner.adapters = {}
+    runner._voice_mode = {}
+    runner._session_db = None
+    runner._pending_approvals = {}
+    runner._background_tasks = set()
+    runner.config = {}
+    runner.session_store = MagicMock()
+    entry = MagicMock()
+    entry.session_id = "session-1"
+    entry.session_key = "telegram:u1:c1"
+    runner.session_store.get_or_create_session.return_value = entry
+    runner.session_store.load_transcript.return_value = []
+    runner._session_key_for_source = lambda source: "telegram:u1:c1"
+    return runner
+
+
+class TestGatewayLocalizedSlashReplies:
+    @pytest.mark.asyncio
+    async def test_title_and_resume_db_errors_are_localized(self):
+        _write_ui_overlay()
+        runner = _make_runner()
+
+        assert await runner._handle_title_command(_make_event("/title")) == "会话数据库不可用。"
+        assert await runner._handle_resume_command(_make_event("/resume")) == "会话数据库不可用。"
+
+    @pytest.mark.asyncio
+    async def test_branch_empty_state_is_localized(self):
+        _write_ui_overlay()
+        runner = _make_runner()
+        runner._session_db = MagicMock()
+
+        result = await runner._handle_branch_command(_make_event("/branch"))
+
+        assert "还没有可分叉的对话" in result
+        assert "No conversation to branch" not in result
+
+    @pytest.mark.asyncio
+    async def test_approve_and_deny_empty_state_are_localized(self):
+        _write_ui_overlay()
+        runner = _make_runner()
+
+        with patch("tools.approval.has_blocking_approval", return_value=False):
+            assert await runner._handle_approve_command(_make_event("/approve")) == "没有等待批准的命令。"
+            assert await runner._handle_deny_command(_make_event("/deny")) == "没有等待拒绝的命令。"
+
+    @pytest.mark.asyncio
+    async def test_insights_and_reload_mcp_errors_are_localized(self):
+        _write_ui_overlay()
+        runner = _make_runner()
+
+        result = await runner._handle_insights_command(_make_event("/insights --days nope"))
+        assert "参数无效" in result
+        assert "Invalid --days" not in result
+
+        with patch("tools.mcp_tool.shutdown_mcp_servers", side_effect=RuntimeError("boom")):
+            result = await runner._handle_reload_mcp_command(_make_event("/reload-mcp"))
+        assert "MCP 重载失败" in result
+        assert "MCP reload failed" not in result
+
+    @pytest.mark.asyncio
+    async def test_update_platform_error_is_localized(self):
+        _write_ui_overlay()
+        runner = _make_runner()
+
+        result = await runner._handle_update_command(_make_event("/update", platform=Platform.API_SERVER))
+
+        assert "/update 只能从消息平台使用" in result
+        assert "only available from messaging platforms" not in result
