diff --git a/hermes_cli/skin_engine.py b/hermes_cli/skin_engine.py
index 6ca6f8adf..85399ed52 100644
--- a/hermes_cli/skin_engine.py
+++ b/hermes_cli/skin_engine.py
@@ -120,6 +120,91 @@ from hermes_constants import get_hermes_home
 
 logger = logging.getLogger(__name__)
 
+# =============================================================================
+# Localization (zh-CN overlay)
+# =============================================================================
+
+_LOCALIZATION_DIR = get_hermes_home() / "localization"
+
+
+def _load_localization(filename: str) -> dict:
+    """Load a YAML localization file from ~/.hermes/localization/"""
+    path = _LOCALIZATION_DIR / filename
+    if path.is_file():
+        try:
+            import yaml
+            with open(path, "r", encoding="utf-8") as f:
+                data = yaml.safe_load(f)
+            if isinstance(data, dict):
+                return data
+        except Exception as e:
+            logger.debug("Failed to load localization %s: %s", filename, e)
+    return {}
+
+
+def get_ui_text(key: str, default: str = "", **format_args) -> str:
+    """Look up a UI text from ui.zh-CN.yaml"""
+    _ui_cache = getattr(get_ui_text, '_cache', None)
+    if _ui_cache is None:
+        _ui_cache = _load_localization("ui.zh-CN.yaml")
+        get_ui_text._cache = _ui_cache
+    messages = _ui_cache.get("messages", {})
+    value = messages.get(key, default)
+    if value and format_args:
+        try:
+            return value.format(**format_args)
+        except (KeyError, IndexError):
+            return value
+    return value
+
+
+def get_command_desc(command_name: str, default: str = "") -> str:
+    """Look up command description from commands.zh-CN.yaml"""
+    _cache = getattr(get_command_desc, '_cache', None)
+    if _cache is None:
+        _cache = _load_localization("commands.zh-CN.yaml")
+        get_command_desc._cache = _cache
+    return _cache.get(command_name, default) or default
+
+
+def get_tip_text(tip_text: str) -> str:
+    """Look up tip translation from tips.zh-CN.yaml"""
+    _cache = getattr(get_tip_text, '_cache', None)
+    if _cache is None:
+        _cache = _load_localization("tips.zh-CN.yaml")
+        get_tip_text._cache = _cache
+    return _cache.get(tip_text, tip_text) or tip_text
+
+
+def get_skill_desc(skill_name: str, default: str = "") -> str:
+    """Look up skill description from skills.zh-CN.yaml"""
+    _cache = getattr(get_skill_desc, '_cache', None)
+    if _cache is None:
+        _cache = _load_localization("skills.zh-CN.yaml")
+        get_skill_desc._cache = _cache
+    return _cache.get(skill_name, default) or default
+
+
+def get_skin_text(skin_name: str, key: str, default: str = "") -> str:
+    """Look up skin text from skins.zh-CN.yaml"""
+    _cache = getattr(get_skin_text, '_cache', None)
+    if _cache is None:
+        _cache = _load_localization("skins.zh-CN.yaml")
+        get_skin_text._cache = _cache
+    skin_data = _cache.get("skins", {}).get(skin_name, {})
+    if not skin_data:
+        return default
+    # Navigate nested keys like "branding.welcome"
+    parts = key.split(".")
+    obj = skin_data
+    for part in parts:
+        if isinstance(obj, dict):
+            obj = obj.get(part)
+        else:
+            return default
+    return str(obj) if obj is not None else default
+
+
 
 # =============================================================================
 # Skin data structure
