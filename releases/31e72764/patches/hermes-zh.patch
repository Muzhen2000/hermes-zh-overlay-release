+def _load_runtime_localization_module() -> Any | None:
+    global _RUNTIME_LOCALIZATION_MODULE
+    if _RUNTIME_LOCALIZATION_MODULE is not None:
+        return _RUNTIME_LOCALIZATION_MODULE
+
+    runtime_path = get_hermes_home() / "localization" / "hermes_zh_runtime.py"
+    if not runtime_path.exists():
+        _RUNTIME_LOCALIZATION_MODULE = False
+        return None
+
+    try:
+        spec = importlib.util.spec_from_file_location("hermes_zh_runtime", runtime_path)
+        if spec is None or spec.loader is None:
+            _RUNTIME_LOCALIZATION_MODULE = False
+            return None
+        module = importlib.util.module_from_spec(spec)
+        spec.loader.exec_module(module)
+        _RUNTIME_LOCALIZATION_MODULE = module
+        return module
+    except Exception:
+        logger.debug("Failed to load localization runtime from %s", runtime_path, exc_info=True)
+        _RUNTIME_LOCALIZATION_MODULE = False
+        return None
+
+
+def _call_runtime_localization(func_name: str, fallback: Any, *args: Any, **kwargs: Any) -> Any:
+    module = _load_runtime_localization_module()
+    if module is None:
+        return fallback
+    func = getattr(module, func_name, None)
+    if not callable(func):
+        return fallback
+    try:
+        return func(*args, **kwargs)
+    except Exception:
+        logger.debug("Localization runtime call failed: %s", func_name, exc_info=True)
+        return fallback
+
+
+def normalize_skill_slug(name: str) -> str:
+    fallback = str(name or "").strip().lower().replace(" ", "-").replace("_", "-")
+    return _call_runtime_localization("normalize_skill_slug", fallback, name)
+
+
+def get_command_description(command_name: str, default: str) -> str:
+    return _call_runtime_localization("get_command_description", default, command_name, default)
+
+
+def get_command_meta(key: str, default: str) -> str:
+    return _call_runtime_localization("get_command_meta", default, key, default)
+
+
