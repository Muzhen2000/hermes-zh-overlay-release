+    func = getattr(module, name, None)
+    if not callable(func):
+        return fallback
+    try:
+        return func(*args, **kwargs)
+    except Exception:
+        logger.debug("Localization runtime call failed: %s", name, exc_info=True)
+        return fallback
+
